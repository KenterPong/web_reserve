# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# LINE Login
LINE_CLIENT_ID=your-line-channel-id
LINE_CLIENT_SECRET=your-line-channel-secret
LINE_CALLBACK_URL=https://www.yourdomain.com/auth/callback
NEXT_PUBLIC_LINE_CLIENT_ID=your-line-channel-id
NEXT_PUBLIC_LINE_CALLBACK_URL=https://www.yourdomain.com/auth/callback

# App
NEXT_PUBLIC_APP_URL=https://www.yourdomain.com

# Rate limit（MVP：程序內記憶體；Production 可改 Redis）
# 建立預約（POST /api/appointments）：每 IP + workerId 每小時上限
# - 預設：5
# - 設為 0 或負數：關閉限流
APPOINTMENTS_POST_RATE_LIMIT=5
